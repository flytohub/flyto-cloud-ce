# Copy this file to install/.env.ce and replace both values before exposing CE.
FLYTO_EDITION_PROFILE=cloud_ce
DEPLOYMENT_MODE=offline
API_HOST=0.0.0.0
API_PORT=9000

FLYTO_OFFLINE_DB_PATH=/data/flyto/offline.db
FLYTO_OFFLINE_LOGIN_MODE=jwt
FLYTO_OFFLINE_AUTH_SECRET=replace-with-at-least-32-random-characters

FLYTO_WARROOM_IMPORT_DIR=/data/warroom-inbox
FLYTO_WARROOM_BUNDLE_HMAC_SECRET=replace-with-a-separate-random-secret

FLYTO_BACKEND_URL=http://127.0.0.1:9000
FLYTO_MCP_ALLOW_UNAUTH_LOCAL=false
FLYTO_LOCAL_SECRET=replace-with-a-separate-local-secret
